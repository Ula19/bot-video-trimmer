# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api, файлы до 2 ГБ)
API_ID=
API_HASH=

# Юзернейм бота (без @)
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_trimmer
DB_USER=bot_4_trimmer
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== BOT API ====================

# URL Local Bot API — выставляется через docker-compose environment,
# но можно переопределить здесь для локальной разработки
# TELEGRAM_API_SERVER=http://bot-api:8081
